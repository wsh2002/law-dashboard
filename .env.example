# 智谱（GLM）：本地推荐只设此项，由 Vite 代理注入，密钥不进前端包
ZHIPU_API_KEY=

# DeepSeek（deepseek-v4-flash / deepseek-v4-pro）：同上；只填 key 本体，代码会自动加 Bearer
DEEPSEEK_API_KEY=

# 火山方舟 · 豆包（文案助手）
# 填火山方舟“API Key”，不是云账号 Access Key ID / Secret Access Key；代码会自动加 Bearer
DOUBAO_API_KEY=
# 可选：控制台「快捷 API」里的 model（如 doubao-seed-2-0-pro-260215）或推理接入点 ep-xxxx；不设则用代码内默认 ID
DOUBAO_ENDPOINT_ID=
# 或与上一项二选一（会进前端包）：VITE_DOUBAO_MODEL=doubao-seed-2-0-pro-260215

# 阿里云 DashScope · 通义（文案助手 qwen3.6-plus；国际区可加 VITE_DASHSCOPE_BASE_URL）
DASHSCOPE_API_KEY=

# 若代理未带上 Authorization，可二选一或同时配置（会打进构建产物，生产静态站直连时必需）
# VITE_ZHIPU_API_KEY=
# VITE_DEEPSEEK_API_KEY=
# VITE_DOUBAO_API_KEY=
# VITE_DASHSCOPE_API_KEY=
